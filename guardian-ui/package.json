{
  "name": "guardian-ui",
  "version": "0.1.0",
  "description": "Neuroprotective cognitive infrastructure — integrated workspace with chat, terminal, notes, and hierarchical memory",
  "main": "main.js",
  "scripts": {
    "dev": "vite",
    "electron": "electron .",
    "start": "concurrently \"npm run dev\" \"npx wait-on http://localhost:5173 && npm run electron\"",
    "typecheck": "tsc --noEmit",
    "compile": "tsc",
    "build": "tsc && vite build",
    "rebuild": "npx @electron/rebuild -f -w node-pty",
    "dist": "npm run build && electron-builder --config electron-builder.yml",
    "dist:win": "npm run build && electron-builder --config electron-builder.yml --win",
    "dist:mac": "npm run build && electron-builder --config electron-builder.yml --mac",
    "dist:linux": "npm run build && electron-builder --config electron-builder.yml --linux"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^5.5.0",
    "allotment": "^1.20.2",
    "better-sqlite3": "^12.6.2",
    "d3-force": "^3.0.0",
    "electron-updater": "^6.7.3",
    "node-pty": "1.2.0-beta.10",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "typescript": "^5.9.3",
    "vite": "^6.0.5"
  }
}
