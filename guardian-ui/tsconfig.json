{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "lib",
    "rootDir": "lib",
    "declaration": true,
    "resolveJsonModule": true,
    "allowJs": true
  },
  "include": ["lib/**/*.ts"],
  "exclude": ["node_modules", "dist", "release"]
}
